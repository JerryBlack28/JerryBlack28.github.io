---
import MainGridLayout from "../layouts/MainGridLayout.astro";
import { projectsData, type Project } from "../data/projects";

const statusLabel: Record<Project["status"], { zh: string; en: string }> = {
	completed: { zh: "已完成", en: "Completed" },
	"in-progress": { zh: "进行中", en: "In Progress" },
	planned: { zh: "计划中", en: "Planned" },
};

const statusClass: Record<Project["status"], string> = {
	completed: "bg-[oklch(0.95_0.05_var(--hue))] text-[oklch(0.45_0.15_var(--hue))]",
	"in-progress": "bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400",
	planned: "bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400",
};

const categories = [
	{ id: "all", label: "全部", labelEn: "All" },
	{ id: "web", label: "Web 应用", labelEn: "Web Applications" },
	{ id: "mobile", label: "移动应用", labelEn: "Mobile Applications" },
	{ id: "desktop", label: "桌面应用", labelEn: "Desktop Applications" },
	{ id: "other", label: "其他", labelEn: "Other" },
];

const countByCategory = (id: string) =>
	id === "all"
		? projectsData.length
		: projectsData.filter((p) => p.category === id).length;

const visibleCategories = categories.filter(
	(c) => c.id === "all" || countByCategory(c.id) > 0,
);
---

<MainGridLayout title="项目" description="My development project portfolio">
	<div class="card-base z-10 px-9 py-6 relative w-full">
		<div class="flex items-center gap-3 mb-1">
			<div class="w-1 h-9 bg-[var(--primary)] rounded-full"></div>
			<h1 class="text-3xl font-bold text-black/90 dark:text-white/90">
				<span data-lang="zh">项目</span><span data-lang="en">Projects</span>
			</h1>
		</div>
		<div class="mb-8"></div>

		{projectsData.length === 0 ? (
			<div class="text-center py-24 text-neutral-400 dark:text-neutral-500">
				<div class="text-5xl mb-4">🚧</div>
				<p class="text-lg"><span data-lang="zh">项目整理中，敬请期待</span><span data-lang="en">Coming soon...</span></p>
			</div>
		) : (
			<>
				<div class="flex flex-wrap gap-3 mb-8" id="filter-bar">
					{visibleCategories.map((cat, i) => (
						<button
							data-filter={cat.id}
							class:list={[
								"filter-btn flex items-center gap-2 px-5 py-2 rounded-full text-sm font-medium transition-all",
								i === 0
									? "bg-[var(--primary)] text-white shadow-md"
									: "bg-[var(--btn-plain-bg)] text-[var(--btn-content)] hover:bg-[var(--btn-plain-bg-hover)]",
							]}
						>
							<span data-lang="zh">{cat.label}</span>
							<span data-lang="en">{cat.labelEn}</span>
							<span class="text-xs opacity-70">({countByCategory(cat.id)})</span>
						</button>
					))}
				</div>

				<div class="grid grid-cols-1 md:grid-cols-2 gap-5" id="project-grid">
					{projectsData.map((p) => (
						<div
							class="project-card rounded-2xl border border-neutral-200/60 dark:border-neutral-700/60 overflow-hidden hover:shadow-xl transition-all bg-[var(--card-bg)]"
							data-category={p.category}
						>
							{p.image && (
								<div class="h-48 overflow-hidden bg-neutral-100 dark:bg-neutral-800">
									<img src={p.image} alt={p.title} class="w-full h-full object-cover" loading="lazy" />
								</div>
							)}
							<div class="p-5">
								<div class="flex items-start justify-between gap-3 mb-2">
									<h3 class="text-lg font-bold text-black/90 dark:text-white/90">{p.title}</h3>
									<span class:list={["text-xs px-3 py-1 rounded-full font-medium whitespace-nowrap", statusClass[p.status]]}>
										<span data-lang="zh">{statusLabel[p.status].zh}</span><span data-lang="en">{statusLabel[p.status].en}</span>
									</span>
								</div>
								<p class="text-sm text-neutral-500 dark:text-neutral-400 mb-4 line-clamp-2">{p.descriptionEn ? (<><span data-lang="zh">{p.description}</span><span data-lang="en">{p.descriptionEn}</span></>) : p.description}</p>
								<div class="flex flex-wrap gap-1.5 mb-4">
									{p.techStack.map((tech) => (
										<span class="text-xs px-2.5 py-1 bg-[oklch(0.95_0.05_var(--hue))] dark:bg-[oklch(0.28_0.05_var(--hue))] text-[oklch(0.45_0.15_var(--hue))] dark:text-[oklch(0.75_0.10_var(--hue))] rounded-full">
											{tech}
										</span>
									))}
								</div>
								<div class="flex gap-2">
									{p.liveUrl && (
										<a href={p.liveUrl} target="_blank" rel="noopener noreferrer"
											class="flex-1 flex items-center justify-center gap-2 py-2 rounded-xl bg-[oklch(0.95_0.05_var(--hue))] dark:bg-[oklch(0.28_0.05_var(--hue))] text-[oklch(0.45_0.15_var(--hue))] dark:text-[oklch(0.75_0.10_var(--hue))] text-sm hover:opacity-80 transition-opacity">
											<svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6"/><path d="M15 3h6v6"/><path d="M10 14L21 3"/></svg>
											Visit Project
										</a>
									)}
									{p.githubUrl && (
										<a href={p.githubUrl} target="_blank" rel="noopener noreferrer"
											class:list={["flex items-center justify-center gap-2 py-2 rounded-xl bg-[oklch(0.95_0.05_var(--hue))] dark:bg-[oklch(0.28_0.05_var(--hue))] text-[oklch(0.45_0.15_var(--hue))] dark:text-[oklch(0.75_0.10_var(--hue))] text-sm hover:opacity-80 transition-opacity", p.liveUrl ? "px-4" : "flex-1"]}>
											<svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>
											{!p.liveUrl && "GitHub"}
										</a>
									)}
								</div>
							</div>
						</div>
					))}
				</div>
			</>
		)}
	</div>
</MainGridLayout>

<script>
	const btns = document.querySelectorAll<HTMLButtonElement>(".filter-btn");
	const cards = document.querySelectorAll<HTMLElement>(".project-card");
	btns.forEach((btn) => {
		btn.addEventListener("click", () => {
			const f = btn.dataset.filter;
			btns.forEach((b) => {
				b.classList.remove("bg-[var(--primary)]", "text-white", "shadow-md");
				b.classList.add("bg-[var(--btn-plain-bg)]", "text-[var(--btn-content)]");
			});
			btn.classList.add("bg-[var(--primary)]", "text-white", "shadow-md");
			btn.classList.remove("bg-[var(--btn-plain-bg)]", "text-[var(--btn-content)]");
			cards.forEach((c) => {
				(c as HTMLElement).style.display = f === "all" || c.dataset.category === f ? "" : "none";
			});
		});
	});
</script>
