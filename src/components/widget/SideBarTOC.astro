---
import type { MarkdownHeading } from "astro";
import TOC from "./TOC.astro";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	headings: MarkdownHeading[];
	class?: string;
	style?: string;
}
const { headings, style } = Astro.props;
const className = Astro.props.class;
---
{/* #toc is the Swup container — must exist on every page, even when
   there are no headings, so Swup doesn't fall back to a full reload.
   Use display:contents so the inner WidgetLayout behaves as a direct
   child of the flex sidebar-sticky (preserves gap and card layout). */}
<div id="toc" class:list={[headings.length === 0 ? "hidden" : "contents"]}>
	{headings.length > 0 && (
		<WidgetLayout name="目录" nameEn="Table of Contents" id="sidebar-toc" class={className} style={style}>
			<div id="toc-inner-wrapper" class="relative max-h-[24rem] overflow-y-auto overflow-x-hidden hide-scrollbar">
				<TOC headings={headings} />
			</div>
		</WidgetLayout>
	)}
</div>
