---
import type { MarkdownHeading } from "astro";
import TOC from "./TOC.astro";
import WidgetLayout from "./WidgetLayout.astro";

interface Props {
	headings: MarkdownHeading[];
	class?: string;
	style?: string;
}
const { headings, style } = Astro.props;
const className = Astro.props.class;
---
{headings.length > 0 && (
	<WidgetLayout name="目录" nameEn="Table of Contents" id="sidebar-toc" class={className} style={style}>
		<div id="toc-inner-wrapper" class="relative max-h-[calc(100vh_-_20rem)] overflow-y-auto overflow-x-hidden hide-scrollbar">
			<div id="toc">
				<TOC headings={headings} />
			</div>
		</div>
	</WidgetLayout>
)}
